{
  "name": "MichelinGuidesLight",
  "schema_version": "3.3-light",
  "type": "json_schema",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "contains_no_content_of_requested_type": {
        "type": "boolean",
        "description": "True if the page contains no restaurant or hotel entries (maps, legends, index, ads). False if at least one entry is present."
      },
      "active_city_or_town": {
        "type": ["string", "null"],
        "description": "Last bold all-caps town heading visible on this page. Null only if no heading appears (e.g. pure map page)."
      },
      "entries": {
        "type": "array",
        "description": "Michelin Guide establishments extracted from this page. NULL SEMANTICS: For COMPLETE entries (entry_is_fragment = false), every boolean field MUST be true or false, never null. awards.stars MUST be 0 (not null) if no star glyph is visible. For FRAGMENT entries (entry_is_fragment = true), fields not visible on this page may be null.",
        "items": {
          "type": "object",
          "description": "One establishment entry from a Michelin Guide page.",
          "properties": {
            "establishment_name": {
              "type": "string",
              "description": "Restaurant name exactly as printed."
            },
            "location": {
              "type": "object",
              "description": "Locality from the guide heading.",
              "properties": {
                "city_or_town": {
                  "type": ["string", "null"],
                  "description": "City or town name."
                },
                "neighbourhood_or_area": {
                  "type": ["string", "null"],
                  "description": "Neighbourhood or area within the city."
                }
              },
              "required": ["city_or_town", "neighbourhood_or_area"],
              "additionalProperties": false
            },
            "address": {
              "type": "object",
              "description": "Postal address details if printed.",
              "properties": {
                "street": {
                  "type": ["string", "null"],
                  "description": "Street name."
                },
                "house_number": {
                  "type": ["string", "null"],
                  "description": "House or building number."
                },
                "postal_code": {
                  "type": ["string", "null"],
                  "description": "Postal or ZIP code."
                }
              },
              "required": ["street", "house_number", "postal_code"],
              "additionalProperties": false
            },
            "awards": {
              "type": "object",
              "description": "Distinctions exactly as printed.",
              "properties": {
                "stars": {
                  "type": ["integer", "null"],
                  "description": "Michelin Stars (0-3). Use 0 if no star glyph is visible on a complete entry.",
                  "minimum": 0,
                  "maximum": 3
                },
                "bib_gourmand": {
                  "type": ["boolean", "null"],
                  "description": "Bib Gourmand award (bibendum - delicious - face symbol/emoji)."
                },
                "michelin_plate": {
                  "type": ["boolean", "null"],
                  "description": "Michelin Plate or Selected Restaurant (plate and fork symbol/emoji)."
                },
                "pleasant_marker": {
                  "type": ["boolean", "null"],
                  "description": "Pleasant or charming establishment marker (birdlike symbol in guide pages; heart emoji in transcriptions)."
                },
                "hotel_class": {
                  "type": ["integer", "null"],
                  "description": "Michelin hotel comfort class (1-5); count of consecutive hotel-pavilion glyphs at entry start. Null if no hotel-pavilion glyph is visible.",
                  "minimum": 1,
                  "maximum": 5
                },
                "restaurant_class": {
                  "type": ["integer", "null"],
                  "description": "Michelin restaurant comfort class (1-5); count of consecutive cutlery glyphs at entry start. Null if no cutlery glyph is visible.",
                  "minimum": 1,
                  "maximum": 5
                }
              },
              "required": [
                "stars",
                "bib_gourmand",
                "michelin_plate",
                "pleasant_marker",
                "hotel_class",
                "restaurant_class"
              ],
              "additionalProperties": false
            },
            "cuisine": {
              "type": "object",
              "description": "Culinary style and specialty information.",
              "properties": {
                "styles": {
                  "type": ["array", "null"],
                  "description": "Primary cuisine type label as printed (e.g. 'Cuisine traditionnelle', 'Italian') or inferred from inspectors' note dish mentions.",
                  "items": {
                            "type": "string",
                            "enum": [
                              "french",
                              "italian",
                              "german_austrian",
                              "iberian",
                              "british",
                              "nordic_scandinavian",
                              "benelux",
                              "mediterranean",
                              "asian",
                              "fusion",
                              "haute_cuisine",
                              "contemporary_european",
                              "avant_garde",
                              "traditional_regional",
                              "international",
                              "other"
                            ]
                          }
                },
                "specialties": {
                  "type": ["array", "null"],
                  "description": "Signature dishes or specialties mentioned in the guide.",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": ["styles", "specialties"],
              "additionalProperties": false
            },
            "pricing": {
              "type": "object",
              "description": "Menu and a-la-carte price ranges.",
              "properties": {
                "currency": {
                  "type": ["string", "null"],
                  "description": "ISO 4217 currency code (e.g. 'EUR', 'GBP', 'CHF', 'FRF', 'DEM')."
                },
                "menu_price_min": {
                  "type": ["number", "null"],
                  "description": "Minimum set menu price."
                },
                "menu_price_max": {
                  "type": ["number", "null"],
                  "description": "Maximum set menu price."
                },
                "a_la_carte_price_min": {
                  "type": ["number", "null"],
                  "description": "Minimum a la carte price."
                },
                "a_la_carte_price_max": {
                  "type": ["number", "null"],
                  "description": "Maximum a la carte price."
                },
                "lunch_menu_price": {
                  "type": ["number", "null"],
                  "description": "Fixed lunch menu price if specified separately."
                }
              },
              "required": [
                "currency",
                "menu_price_min",
                "menu_price_max",
                "a_la_carte_price_min",
                "a_la_carte_price_max",
                "lunch_menu_price"
              ],
              "additionalProperties": false
            },
            "rooms": {
              "type": "object",
              "description": "Room details if establishment has letting rooms.",
              "properties": {
                "room_count": {
                  "type": ["integer", "null"],
                  "description": "Number of guest rooms."
                },
                "room_price_min": {
                  "type": ["number", "null"],
                  "description": "Minimum room price per night."
                },
                "room_price_max": {
                  "type": ["number", "null"],
                  "description": "Maximum room price per night."
                }
              },
              "required": ["room_count", "room_price_min", "room_price_max"],
              "additionalProperties": false
            },
            "accepts_credit_cards": {
              "type": ["boolean", "null"],
              "description": "Any credit card payment symbols visible near the entry."
            },
            "inspector_note": {
              "type": ["string", "null"],
              "description": "Verbatim inspector prose note (2-3 lines, introduced 2003). Null for pre-2003 editions."
            },
            "entry_is_fragment": {
              "type": "boolean",
              "description": "True if entry is incomplete because it spans a page boundary."
            }
          },
          "required": [
            "establishment_name",
            "location",
            "address",
            "awards",
            "cuisine",
            "pricing",
            "rooms",
            "accepts_credit_cards",
            "inspector_note",
            "entry_is_fragment"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "contains_no_content_of_requested_type",
      "active_city_or_town",
      "entries"
    ],
    "additionalProperties": false
  }
}
