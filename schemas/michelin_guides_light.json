{
  "name": "MichelinGuidesLight",
  "schema_version": "3.4-light",
  "type": "json_schema",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "contains_no_content_of_requested_type": {
        "type": "boolean",
        "description": "True if the page contains no restaurant or hotel entries (maps, legends, index, ads). False if at least one entry is present."
      },
      "active_city_or_town": {
        "type": ["string", "null"],
        "description": "Last bold all-caps town heading visible on this page. Null only if no heading appears (e.g. pure map page)."
      },
      "entries": {
        "type": "array",
        "description": "Michelin Guide establishments extracted from this page. NULL SEMANTICS: For COMPLETE entries (entry_is_fragment = false), every boolean field MUST be true or false, never null. awards.stars MUST be 0 (not null) if no star glyph is visible. For FRAGMENT entries (entry_is_fragment = true), fields not visible on this page may be null.",
        "items": {
          "type": "object",
          "description": "One establishment entry from a Michelin Guide page.",
          "properties": {
            "establishment_name": {
              "type": "string",
              "description": "Restaurant name exactly as printed."
            },
            "location": {
              "type": "object",
              "description": "Locality from the guide heading.",
              "properties": {
                "city_or_town": {
                  "type": ["string", "null"],
                  "description": "City or town name."
                },
                "neighbourhood_or_area": {
                  "type": ["string", "null"],
                  "description": "Neighbourhood or area within the city."
                }
              },
              "required": ["city_or_town", "neighbourhood_or_area"],
              "additionalProperties": false
            },
            "address": {
              "type": "object",
              "description": "Postal address details if printed.",
              "properties": {
                "street": {
                  "type": ["string", "null"],
                  "description": "Street name."
                },
                "house_number": {
                  "type": ["string", "null"],
                  "description": "House or building number."
                },
                "postal_code": {
                  "type": ["string", "null"],
                  "description": "Postal or ZIP code."
                }
              },
              "required": ["street", "house_number", "postal_code"],
              "additionalProperties": false
            },
            "awards": {
              "type": "object",
              "description": "Distinctions exactly as printed.",
              "properties": {
                "stars": {
                  "type": ["integer", "null"],
                  "description": "Michelin Stars (0-3). Flower-shaped red rosettes on the name line (category 1 in context image). Count visible rosettes; 0 if none on a complete entry.",
                  "minimum": 0,
                  "maximum": 3
                },
                "bib_gourmand": {
                  "type": ["boolean", "null"],
                  "description": "Bib Gourmand. Round smiling Bibendum face on name line (category 4 in context image). Introduced 1997; false for earlier editions."
                },
                "michelin_plate": {
                  "type": ["boolean", "null"],
                  "description": "Michelin Plate (2016-2021) or Selected Restaurant (2022+). Plate-and-cutlery icon on name line. false outside active years."
                },
                "pleasant_marker": {
                  "type": ["boolean", "null"],
                  "description": "Pleasant establishment marker. Stylized decorative mark (flower, bird, or small red symbol) on the name line."
                },
                "hotel_class": {
                  "type": ["integer", "null"],
                  "description": "Hotel comfort class (1-5). Count of hotel-pavilion glyphs — house/building icons of increasing complexity (category 2 in context image). Null if not a hotel.",
                  "minimum": 1,
                  "maximum": 5
                },
                "restaurant_class": {
                  "type": ["integer", "null"],
                  "description": "Restaurant comfort class (1-5). Count of crossed fork-and-spoon glyphs (category 3 in context image). Comfort rating, not food quality. Null if not a restaurant.",
                  "minimum": 1,
                  "maximum": 5
                }
              },
              "required": [
                "stars",
                "bib_gourmand",
                "michelin_plate",
                "pleasant_marker",
                "hotel_class",
                "restaurant_class"
              ],
              "additionalProperties": false
            },
            "cuisine": {
              "type": "object",
              "description": "Culinary origin, style, and specialty information. Derive cuisine_origin and culinary_style ONLY from what this guide page states about the entry (printed cuisine descriptors, e.g. 'Cuisine italienne', 'Italian', and specialty dish mentions). If the page gives no cuisine information for the entry, set both to null -- do not guess from the establishment's location or name.",
              "properties": {
                "cuisine_origin": {
                  "type": ["array", "null"],
                  "description": "National or geographic culinary tradition(s) of the cooking, as stated on the page (cuisine text descriptors or clearly attributable specialties). Null if the page gives no cuisine information.",
                  "items": {
                    "type": "string",
                    "enum": [
                      "french",
                      "italian",
                      "german_austrian_swiss",
                      "iberian",
                      "british",
                      "nordic_scandinavian",
                      "belgian_dutch",
                      "mediterranean",
                      "japanese",
                      "chinese",
                      "south_asian",
                      "southeast_asian",
                      "middle_eastern",
                      "north_african",
                      "african",
                      "mexican",
                      "south_american",
                      "american",
                      "international",
                      "other"
                    ]
                  }
                },
                "culinary_style": {
                  "type": ["array", "null"],
                  "description": "Stylistic register(s) of the cooking (named movement or school, e.g. haute cuisine classique, nouvelle cuisine, bistronomy), as stated on the page. Independent of geographic origin: an entry may carry both an origin and a style, either one, or neither. Null if the page gives no stylistic information.",
                  "items": {
                    "type": "string",
                    "enum": [
                      "haute_cuisine_classique",
                      "nouvelle_cuisine",
                      "farm_to_table",
                      "neue_deutsche_kueche",
                      "cuisine_du_terroir",
                      "nueva_cocina_vasca",
                      "cucina_italiana_moderna",
                      "fusion",
                      "molecular_gastronomy",
                      "plant_forward",
                      "live_fire",
                      "modern_british",
                      "avant_garde",
                      "bistronomy",
                      "new_nordic",
                      "zero_waste",
                      "other"
                    ]
                  }
                },
                "specialties": {
                  "type": ["array", "null"],
                  "description": "Signature dishes or specialties mentioned in the guide.",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": ["cuisine_origin", "culinary_style", "specialties"],
              "additionalProperties": false
            },
            "pricing": {
              "type": "object",
              "description": "Menu and a-la-carte price ranges.",
              "properties": {
                "currency": {
                  "type": ["string", "null"],
                  "description": "ISO 4217 currency code (e.g. 'EUR', 'GBP', 'CHF', 'FRF', 'DEM')."
                },
                "menu_price_min": {
                  "type": ["number", "null"],
                  "description": "Minimum set menu price."
                },
                "menu_price_max": {
                  "type": ["number", "null"],
                  "description": "Maximum set menu price."
                },
                "a_la_carte_price_min": {
                  "type": ["number", "null"],
                  "description": "Minimum a la carte price."
                },
                "a_la_carte_price_max": {
                  "type": ["number", "null"],
                  "description": "Maximum a la carte price."
                },
                "lunch_menu_price": {
                  "type": ["number", "null"],
                  "description": "Fixed lunch menu price if specified separately."
                }
              },
              "required": [
                "currency",
                "menu_price_min",
                "menu_price_max",
                "a_la_carte_price_min",
                "a_la_carte_price_max",
                "lunch_menu_price"
              ],
              "additionalProperties": false
            },
            "rooms": {
              "type": "object",
              "description": "Room details if establishment has letting rooms.",
              "properties": {
                "room_count": {
                  "type": ["integer", "null"],
                  "description": "Number of guest rooms."
                },
                "room_price_min": {
                  "type": ["number", "null"],
                  "description": "Minimum room price per night."
                },
                "room_price_max": {
                  "type": ["number", "null"],
                  "description": "Maximum room price per night."
                }
              },
              "required": ["room_count", "room_price_min", "room_price_max"],
              "additionalProperties": false
            },
            "accepts_credit_cards": {
              "type": ["boolean", "null"],
              "description": "Any credit card payment symbols visible near the entry."
            },
            "inspector_note": {
              "type": ["string", "null"],
              "description": "Verbatim inspector prose note (2-3 lines, introduced 2003). Null for pre-2003 editions."
            },
            "entry_is_fragment": {
              "type": "boolean",
              "description": "True if entry is incomplete because it spans a page boundary."
            }
          },
          "required": [
            "establishment_name",
            "location",
            "address",
            "awards",
            "cuisine",
            "pricing",
            "rooms",
            "accepts_credit_cards",
            "inspector_note",
            "entry_is_fragment"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "contains_no_content_of_requested_type",
      "active_city_or_town",
      "entries"
    ],
    "additionalProperties": false
  }
}
