{
  "name": "MichelinGuides",
  "schema_version": "3.3",
  "type": "json_schema",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "contains_no_content_of_requested_type": {
        "type": "boolean",
        "description": "True if page has no restaurant entries (maps, legends, index, ads). False if at least one entry present."
      },
      "active_city_or_town": {
        "type": ["string", "null"],
        "description": "Last bold all-caps town heading on this page. Null if none visible."
      },
      "entries": {
        "type": "array",
        "description": "Extracted establishments. Complete entries: all booleans true/false (never null); awards.stars = 0 if no star visible. Fragments: unseen fields may be null.",
        "items": {
          "type": "object",
          "description": "One establishment entry.",
          "properties": {
            "establishment_name": {
              "type": "string",
              "description": "Restaurant or establishment name exactly as printed."
            },
            "location": {
              "type": "object",
              "description": "Locality from guide heading.",
              "properties": {
                "city_or_town": {
                  "type": ["string", "null"],
                  "description": "City or town name."
                },
                "neighbourhood_or_area": {
                  "type": ["string", "null"],
                  "description": "Neighbourhood or area within the city."
                }
              },
              "required": ["city_or_town", "neighbourhood_or_area"],
              "additionalProperties": false
            },
            "address": {
              "type": "object",
              "description": "Postal address if printed.",
              "properties": {
                "street": {
                  "type": ["string", "null"],
                  "description": "Street name."
                },
                "house_number": {
                  "type": ["string", "null"],
                  "description": "House or building number."
                },
                "postal_code": {
                  "type": ["string", "null"],
                  "description": "Postal or ZIP code."
                }
              },
              "required": ["street", "house_number", "postal_code"],
              "additionalProperties": false
            },
            "awards": {
              "type": "object",
              "description": "Distinctions exactly as printed.",
              "properties": {
                "stars": {
                  "type": ["integer", "null"],
                  "description": "Michelin Stars (0-3). 0 if no star visible on a complete entry.",
                  "minimum": 0,
                  "maximum": 3
                },
                "bib_gourmand": {
                  "type": ["boolean", "null"],
                  "description": "Bib Gourmand (Bibendum face symbol)."
                },
                "michelin_plate": {
                  "type": ["boolean", "null"],
                  "description": "Michelin Plate (2016-2021) or Selected (2022+)."
                },
                "green_star": {
                  "type": ["boolean", "null"],
                  "description": "Green Star for sustainability (2020+)."
                },
                "pleasant_marker": {
                  "type": ["boolean", "null"],
                  "description": "Pleasant or charming marker."
                },
                "comfort_covers": {
                  "type": ["integer", "null"],
                  "description": "Comfort rating (1-5) from crossed fork-and-spoon glyphs. Not a food quality rating.",
                  "minimum": 1,
                  "maximum": 5
                },
                "new_in_guide": {
                  "type": ["boolean", "null"],
                  "description": "Newly listed in this edition."
                }
              },
              "required": [
                "stars",
                "bib_gourmand",
                "michelin_plate",
                "green_star",
                "pleasant_marker",
                "comfort_covers",
                "new_in_guide"
              ],
              "additionalProperties": false
            },
            "specialties": {
              "type": ["array", "null"],
              "description": "Signature dishes or specialties as printed.",
              "items": {
                "type": "string"
              }
            },
            "pricing": {
              "type": "object",
              "description": "Menu and a-la-carte prices.",
              "properties": {
                "currency": {
                  "anyOf": [
                    {
                      "type": "string",
                      "enum": ["EUR", "GBP", "CHF", "FRF", "DEM", "ITL", "BEF", "NLG", "LUF", "ESP", "PTE"]
                    },
                    {"type": "null"}
                  ],
                  "description": "ISO 4217 code. Null if no price printed."
                },
                "menu_price_min": {
                  "type": ["number", "null"],
                  "description": "Minimum set menu price."
                },
                "a_la_carte_price_min": {
                  "type": ["number", "null"],
                  "description": "Minimum a la carte price."
                }
              },
              "required": [
                "currency",
                "menu_price_min",
                "a_la_carte_price_min"
              ],
              "additionalProperties": false
            },
            "amenities": {
              "type": "object",
              "description": "Boolean flags from printed pictograms.",
              "properties": {
                "wheelchair_access": {
                  "type": ["boolean", "null"],
                  "description": "Wheelchair accessible."
                },
                "air_conditioning": {
                  "type": ["boolean", "null"],
                  "description": "Air conditioning."
                },
                "terrace": {
                  "type": ["boolean", "null"],
                  "description": "Terrace seating."
                },
                "garden_or_park": {
                  "type": ["boolean", "null"],
                  "description": "Garden or park."
                },
                "great_view": {
                  "type": ["boolean", "null"],
                  "description": "Notable view."
                },
                "parking": {
                  "type": ["boolean", "null"],
                  "description": "Parking available."
                },
                "has_rooms": {
                  "type": ["boolean", "null"],
                  "description": "Restaurant or inn with letting rooms."
                }
              },
              "required": [
                "wheelchair_access",
                "air_conditioning",
                "terrace",
                "garden_or_park",
                "great_view",
                "parking",
                "has_rooms"
              ],
              "additionalProperties": false
            },
            "accepts_credit_cards": {
              "type": ["boolean", "null"],
              "description": "True if any credit card symbols visible near entry."
            },
            "inspector_note": {
              "type": ["string", "null"],
              "description": "Verbatim inspector prose (2-3 lines, post-2003). Null for pre-2003 editions."
            },
            "entry_is_fragment": {
              "type": "boolean",
              "description": "True if entry is incomplete because it spans a page boundary. Fill only visible fields."
            }
          },
          "required": [
            "establishment_name",
            "location",
            "address",
            "awards",
            "specialties",
            "pricing",
            "amenities",
            "accepts_credit_cards",
            "inspector_note",
            "entry_is_fragment"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "contains_no_content_of_requested_type",
      "active_city_or_town",
      "entries"
    ],
    "additionalProperties": false
  }
}